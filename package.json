{
  "name": "kochava",
  "version": "1.3.0",
  "description": "Production-ready AI router with semantic tool routing. Runs 60-80% of tasks FREE on local models, escalates complex tasks to Claude API",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "kochava": "./dist/interfaces/kochava.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/interfaces/cli.ts",
    "start": "node dist/interfaces/cli.js",
    "kochava": "node dist/interfaces/kochava.js",
    "server": "node dist/interfaces/server.js",
    "plugin": "node dist/interfaces/plugin_adapter.js",
    "test": "npm run test:build && npm run test:health",
    "test:build": "tsc --noEmit",
    "test:health": "node test/health.test.js",
    "test:integration": "npm run build && node dist/scripts/verify.js",
    "verify": "npm run test:integration",
    "lint": "tsc --noEmit",
    "install-command": "bash scripts/install_command.sh",
    "uninstall-command": "bash scripts/uninstall_command.sh",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "llm",
    "local-models",
    "claude",
    "ollama",
    "code-assistant",
    "routing",
    "free",
    "cost-optimization"
  ],
  "author": "Naor Haimov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NaorHai/kochava.git"
  },
  "bugs": {
    "url": "https://github.com/NaorHai/kochava/issues"
  },
  "homepage": "https://github.com/NaorHai/kochava#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "ollama": "^0.5.0",
    "winston": "^3.11.0",
    "commander": "^11.1.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/express": "^4.17.21",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
