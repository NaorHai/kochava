# ========================================
# LOCAL FREE MODELS (No API Key Required)
# ========================================
# Ollama runs 100% locally on your machine
# These models handle 60-80% of requests
OLLAMA_HOST=http://localhost:11434

# ========================================
# CLAUDE API (Optional for Complex Tasks)
# ========================================
# Only needed for 20-40% of complex requests
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# AWS Bedrock Base URL (Optional - for enterprise/Bedrock users)
# Leave empty for direct Anthropic API
# Example: https://your-bedrock-gateway.com/bedrock
ANTHROPIC_BEDROCK_BASE_URL=

# Skip Bedrock Auth Header (set to 1 if your Bedrock gateway handles auth)
CLAUDE_CODE_SKIP_BEDROCK_AUTH=

# Claude Token Budget (per session)
CLAUDE_TOKEN_BUDGET=8000

# Auto-fallback to local models when Claude fails
# Options: true (default), false
AUTO_FALLBACK_ENABLED=true

# ========================================
# ROUTING CONFIGURATION
# ========================================
ROUTING_MODE=auto
LOCAL_TASK_TIMEOUT=30000

# ========================================
# TOOL INTEGRATION (Skills & MCPs)
# ========================================
# Enable local models to use Claude Code skills and MCPs
# Requires ~/.claude/blueprints/sf-adlc/ configuration
ENABLE_LOCAL_TOOLS=true

# ========================================
# LOGGING
# ========================================
LOG_LEVEL=info
LOG_FILE=./logs/routing.log

# ========================================
# SERVER CONFIGURATION (Optional)
# ========================================
SERVER_PORT=3000

# ========================================
# PLUGIN CONFIGURATION (Optional)
# ========================================
PLUGIN_PORT=3001

# ========================================
# NOTES
# ========================================
# - Local models (Ollama) are FREE and run offline
# - Claude API is only used for complex reasoning
# - You can run with ONLY local models (no API key)
# - Set ANTHROPIC_API_KEY=none to disable Claude routing
