# Kochava Docker Environment Configuration

# Claude API (Optional - leave as 'none' for FREE local-only mode)
ANTHROPIC_API_KEY=none

# Token Budget
CLAUDE_TOKEN_BUDGET=8000

# Auto Fallback
AUTO_FALLBACK_ENABLED=true

# Logging
LOG_LEVEL=info

# Server Ports (if running server/plugin profiles)
SERVER_PORT=3000
PLUGIN_PORT=3001
